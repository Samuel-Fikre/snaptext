{
  "name": "snaptext",
  "version": "0.1.0",
  "description": "Stable text layout snapshots",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format=cjs,esm --dts --out-dir=dist && esbuild src/index.ts --bundle --format=iife --global-name=snaptext --outfile=dist/index.iife.js",
    "dev": "tsup --watch",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "prepublishOnly": "pnpm build"
  },
  "keywords": ["text-layout", "snapshot", "pretext", "ci", "layout-testing", "deterministic-ui"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@chenglou/pretext": "^0.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.4",
    "tslib": "^2.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
